# Solimouv' PWA - GitIgnore Configuration

# ===================================
# NODE.JS & NPM
# ===================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity
package-lock.json
yarn.lock

# ===================================
# SVELTE & VITE BUILD
# ===================================
dist/
build/
.vite/
.svelte-kit/
.env
.env.local
.env.*.local

# ===================================
# RUST & WASM
# ===================================
rust-wasm/target/
rust-wasm/pkg/
rust-wasm/Cargo.lock
rust-wasm/wasm-pack.log
*.wasm
*.wasm.d.ts

# ===================================
# PWA & SERVICE WORKER
# ===================================
sw.js
workbox-*.js
precache-manifest.*.js

# ===================================
# IDE & EDITORS
# ===================================
# VSCode
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains
.idea/
*.iml
*.ipr
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# ===================================
# OPERATING SYSTEMS
# ===================================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# ===================================
# LOGS & DEBUGGING
# ===================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.nyc_output

# ===================================
# RUNTIME & CACHE
# ===================================
.cache/
.temp/
.tmp/
*.pid
*.seed
*.pid.lock

# ===================================
# TESTING & COVERAGE
# ===================================
coverage/
.coverage
.pytest_cache/
.jest/
*.lcov
.nyc_output

# ===================================
# DEPLOYMENT & PRODUCTION
# ===================================
.netlify/
.vercel/
.surge/
.firebase/
.now

# ===================================
# SECURITY & CREDENTIALS
# ===================================
.env
.env.local
.env.production
.env.staging
.env.development
*.pem
*.key
*.cert
.secrets/

# ===================================
# DEPENDENCIES & PACKAGES
# ===================================
bower_components/
jspm_packages/

# ===================================
# TYPESCRIPT
# ===================================
*.tsbuildinfo

# ===================================
# DOCUMENTATION TEMP
# ===================================
docs/_build/
site/

# ===================================
# BACKUP FILES
# ===================================
*.backup
*.bak
*.orig
*.rej
*.swp

# ===================================
# ANALYTICS & MONITORING
# ===================================
.lighthouse/
.axe/

# ===================================
# CUSTOM PROJECT SPECIFIC
# ===================================
# Ignore generated assets
public/generated/

# Ignore temp exports
exports/
temp-files/

# Ignore user uploaded content (if any)
uploads/
user-content/

# Local configuration overrides
config.local.json
settings.local.json

# Development database files (if any)
*.sqlite
*.db

# ===================================
# KEEP THESE FILES (using !)
# ===================================
!.gitkeep
!public/manifest.json
!public/sitemap.xml
!public/robots.txt
!public/*.png
!public/*.svg
!public/*.ico
