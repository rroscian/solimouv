# ===================================
# KEEP THESE IMPORTANT FILES (using !)
# ===================================
!.gitkeep
!.gitattributes
!public/manifest.json
!public/sitemap.xml
!public/robots.txt
!public/*.png
!public/*.svg
!public/*.ico
